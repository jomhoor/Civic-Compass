# Temporary config for initial SSL certificate acquisition
# Replace with civic.conf after obtaining certificates

server {
    listen 80;
    server_name civic.jomhoor.org;

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 200 'Civic Compass — awaiting SSL setup';
        add_header Content-Type text/plain;
    }
}
